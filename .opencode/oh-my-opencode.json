{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",

  // ──────────────────────────────────────────────────────────────────
  // 主模型挂载：gpt-5.4 贯穿 Bong plan-consumption 流水线的所有节点
  // （Sisyphus → Prometheus → Metis → Momus → Atlas）
  //  oracle/librarian/explore 保留 omo 默认路由（分工性价比更好）
  // ──────────────────────────────────────────────────────────────────
  "agents": {
    "Sisyphus":                { "model": "openai/gpt-5.4" },
    "Atlas":                   { "model": "openai/gpt-5.4" },
    "Prometheus (Planner)":    { "model": "openai/gpt-5.4" },
    "Metis (Plan Consultant)": { "model": "openai/gpt-5.4" },
    "Momus (Plan Reviewer)":   { "model": "openai/gpt-5.4" }
  },

  "categories": {
    // 硬逻辑 / 架构决策类 delegate_task 也走 gpt-5.4
    "ultrabrain": { "model": "openai/gpt-5.4" }
  },

  // Sisyphus 编排开启；Prometheus 参与（Bong 的 plan 是定稿态，但仍需
  // Prometheus 把 docs/plan-*.md 规整到 .sisyphus/plans/<name>.md）
  "sisyphus_agent": {
    "disabled": false,
    "default_builder_enabled": false,
    "planner_enabled": true,
    "replace_plan": true
  },

  // git-master 的 commit footer 在 Bong 场景下降噪；保留 co-authored-by
  "git_master": {
    "commit_footer": false,
    "include_co_authored_by": true
  },

  // 并发控制：避免云端开发环境撑爆上游配额
  "background_task": {
    "defaultConcurrency": 3,
    "providerConcurrency": {
      "openai": 3,
      "anthropic": 2
    }
  },

  // 云端无桌面环境 / CI 稳定性 → 关掉交互式/通知类 hook
  // 保留：
  //   directory-agents-injector  —— 从文件向上游走注入 AGENTS.md（本仓库根目录那份）
  //   keyword-detector           —— 认 "ulw" / "high accuracy" 激活 ultrawork + Momus
  //   auto-slash-command         —— prompt 里 /start-work 自动执行
  //   ralph-loop / session-recovery —— 无人值守兜底
  //   claude-code-hooks          —— 继续跑 Bong 现有 .claude/settings.local.json 的 ruff PostToolUse
  //   prometheus-md-only         —— 强制 Prometheus 只能写 .sisyphus/
  //   rules-injector             —— 保留，但本流水线主要靠 AGENTS.md 注入规则
  "disabled_hooks": [
    "startup-toast",
    "auto-update-checker",
    "session-notification",
    "background-notification",
    "agent-usage-reminder"
  ]
}
