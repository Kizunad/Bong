{
  "name": "@bong/schema",
  "version": "0.1.0",
  "description": "Shared IPC schemas for Bong — TypeBox definitions, JSON Schema export, and test samples",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./validate": {
      "types": "./dist/validate.d.ts",
      "import": "./dist/validate.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "generate": "tsx src/generate.ts",
    "generate:check": "tsx src/generate.ts --check",
    "test": "vitest run",
    "check": "tsc --noEmit && npm run generate:check"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
