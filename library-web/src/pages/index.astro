---
import Base from "../layouts/Base.astro";
import BookCard from "../components/BookCard.astro";
import { getCollection } from "astro:content";
import halls from "../lib/halls.json";

const books = await getCollection("books");

const hallOrder = ["cultivation", "geography", "peoples", "ecology", "world"];
const grouped: Record<string, typeof books> = {};
for (const slug of hallOrder) {
  grouped[slug] = books.filter((b) => b.data.hallSlug === slug);
}
---

<Base title="总目">
  <header class="text-center mb-20 ink-reveal">
    <h1 class="lib-title text-5xl mb-5 ink-brush">末法残土图书馆</h1>
    <p class="lib-subtitle font-kai text-base leading-relaxed">
      天地灵气将尽，唯文字不灭。此间所录，皆残土之真。
    </p>
    <div class="lib-stats mt-6 flex justify-center gap-5">
      <span>馆藏 <strong class="ct">{books.length}</strong> 册</span>
      <span style="opacity:0.2">·</span>
      <span>分馆 <strong class="gd">{hallOrder.length}</strong> 座</span>
    </div>
  </header>

  {
    hallOrder.map(
      (slug) =>
        grouped[slug] &&
        grouped[slug].length > 0 && (
          <section class="hall-section ink-reveal">
            <button
              class="hall-toggle"
              data-hall={slug}
              aria-expanded="false"
            >
              <span class="hall-name">{(halls as any)[slug]?.name || slug}</span>
              <span class="hall-line" />
              <span class="hall-desc font-kai">{(halls as any)[slug]?.desc || ""}</span>
              <span class="hall-count font-kai">{grouped[slug].length} 册</span>
              <span class="hall-arrow">›</span>
            </button>

            <div class="hall-body" data-hall-body={slug}>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-3 pt-4">
                {grouped[slug].map((book) => (
                  <BookCard book={book} />
                ))}
              </div>
            </div>
          </section>
        )
    )
  }

  {
    books.length === 0 && (
      <div class="text-center py-24 ink-reveal">
        <p class="font-kai text-lg" style="color:#8a7e70">馆中尚无藏书。</p>
        <p class="text-sm mt-3" style="color:#a09486;opacity:0.5">
          运行 npm run fetch 从仓库拉取馆藏。
        </p>
      </div>
    )
  }
</Base>
