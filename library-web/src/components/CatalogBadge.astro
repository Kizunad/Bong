---
interface Props {
  data: {
    hall: string;
    shelf: string;
    catalogId: string;
    value: string;
    rarity: string;
    status: string;
    anchor: string;
    catalogDate: string;
    lastEdit: string;
  };
}

const { data: d } = Astro.props;

const fields = [
  { label: "分馆", value: d.hall },
  { label: "书架", value: d.shelf },
  { label: "编号", value: d.catalogId },
  { label: "估值", value: d.value },
  { label: "稀有度", value: d.rarity },
  { label: "状态", value: d.status },
  { label: "锚点", value: d.anchor },
  { label: "收录", value: d.catalogDate },
  { label: "整理", value: d.lastEdit },
].filter((f) => f.value);
---

<div class="catalog-badge">
  <div class="badge-title">编目信息</div>
  <div class="grid grid-cols-2 sm:grid-cols-3 gap-x-6 gap-y-2">
    {
      fields.map((f) => (
        <div>
          <div class="field-label">{f.label}</div>
          <div
            class:list={[
              "field-value font-kai",
              f.label === "稀有度" && `rarity-${f.value}`,
              f.label === "状态" && f.value === "在架" && "text-jade",
            ]}
          >
            {f.value}
          </div>
        </div>
      ))
    }
  </div>
</div>
