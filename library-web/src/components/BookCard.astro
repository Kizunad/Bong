---
import type { CollectionEntry } from "astro:content";

interface Props {
  book: CollectionEntry<"books">;
}

const { book } = Astro.props;
const d = book.data;
const href = `/book/${book.slug}`;
---

<a href={href} class="book-card">
  <div class="flex items-start justify-between gap-3">
    <div class="flex-1 min-w-0">
      <div class="card-title truncate">《{d.title}》</div>
      {d.quote && <p class="card-quote line-clamp-2">"{d.quote}"</p>}
      <div class="card-tags">
        {d.shelf && <span class="card-tag">{d.shelf}</span>}
        <span class={`card-tag rarity-${d.rarity}`}>{d.rarity}</span>
        {d.value && <span class="card-tag card-tag-value">{d.value}</span>}
      </div>
    </div>
    <div class="text-right shrink-0 pt-0.5">
      <span class="card-id">{d.catalogId}</span>
      {d.status === "在架" && <div class="card-status mt-1 ml-auto" />}
    </div>
  </div>
</a>
