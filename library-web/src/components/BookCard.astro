---
import type { CollectionEntry } from "astro:content";

interface Props {
  book: CollectionEntry<"books">;
}

const { book } = Astro.props;
const d = book.data;
const href = `/book/${book.slug}`;
---

<a href={href} class="book-card block no-underline">
  <div
    class="rounded-lg p-5 border border-gold/20 bg-gradient-to-br from-parchment to-parchment-dark/40 hover:border-gold/40 transition-colors"
  >
    <div class="flex items-start justify-between gap-3">
      <div class="flex-1 min-w-0">
        <!-- 书名 -->
        <h3 class="font-song text-lg font-bold text-ink truncate">
          《{d.title}》
        </h3>

        <!-- 引语 -->
        {
          d.quote && (
            <p class="mt-1 text-sm text-ink-light italic line-clamp-2 font-kai">
              "{d.quote}"
            </p>
          )
        }

        <!-- 标签行 -->
        <div class="mt-3 flex flex-wrap gap-2 text-xs">
          {
            d.shelf && (
              <span class="px-2 py-0.5 rounded bg-gold/10 text-gold-dim">
                {d.shelf}
              </span>
            )
          }
          <span class={`px-2 py-0.5 rounded rarity-${d.rarity}`}>
            {d.rarity}
          </span>
          {
            d.value && (
              <span class="px-2 py-0.5 rounded bg-cinnabar/8 text-cinnabar">
                {d.value}
              </span>
            )
          }
        </div>
      </div>

      <!-- 编号 -->
      <div class="text-right shrink-0">
        <span class="text-xs text-ink-light opacity-50 font-mono">
          {d.catalogId}
        </span>
        {
          d.status === "在架" && (
            <div class="mt-1 w-2 h-2 rounded-full bg-jade ml-auto" />
          )
        }
      </div>
    </div>
  </div>
</a>
