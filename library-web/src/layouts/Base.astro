---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "末法残土图书馆 — 骨币会贬，记载不朽" } =
  Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} — 末法残土图书馆</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen text-ink">
    <!-- 顶部装饰：双线 -->
    <div class="pt-3 pb-1 max-w-5xl mx-auto px-6">
      <div class="h-px bg-gradient-to-r from-transparent via-cinnabar/50 to-transparent"></div>
      <div class="h-px mt-1 bg-gradient-to-r from-transparent via-gold/30 to-transparent"></div>
    </div>

    <!-- 导航 -->
    <nav class="max-w-5xl mx-auto px-8 py-5 flex items-center justify-between">
      <a href="/" class="group flex items-center gap-3 no-underline">
        <span class="font-song text-2xl font-bold text-cinnabar group-hover:text-cinnabar-light transition-colors tracking-wider">
          末法残土图书馆
        </span>
      </a>
      <span class="text-sm text-ink-light font-kai opacity-60 tracking-wide">
        骨币会贬，记载不朽
      </span>
    </nav>

    <div class="scroll-top"></div>

    <!-- 正文区域 — 书页 -->
    <main class="max-w-5xl mx-auto px-10 py-12">
      <slot />
    </main>

    <div class="scroll-bottom"></div>

    <!-- 页脚 -->
    <footer class="max-w-5xl mx-auto px-8 py-10 text-center">
      <p class="text-sm text-ink-light opacity-40 font-kai tracking-wider">
        凡可立卷者，皆应先入馆藏，再论买卖与实现。
      </p>
    </footer>

    <!-- 底部装饰：双线 -->
    <div class="pb-3 pt-1 max-w-5xl mx-auto px-6">
      <div class="h-px bg-gradient-to-r from-transparent via-gold/30 to-transparent"></div>
      <div class="h-px mt-1 bg-gradient-to-r from-transparent via-cinnabar/40 to-transparent"></div>
    </div>
  </body>
</html>
