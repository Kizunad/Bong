---
import "@fontsource/lxgw-wenkai/300.css";
import "@fontsource/lxgw-wenkai/index.css";
import "@fontsource/lxgw-wenkai/700.css";
import "@fontsource/noto-serif-sc/400.css";
import "@fontsource/noto-serif-sc/700.css";
import "@fontsource/noto-serif-sc/900.css";
import "@fontsource/zhi-mang-xing/chinese-simplified.css";
import "../styles/global.css";
import { ViewTransitions } from "astro:transitions";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "末法残土图书馆 — 骨币会贬，记载不朽" } =
  Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} — 末法残土图书馆</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ViewTransitions />
  </head>
  <body class="min-h-screen">
    <canvas id="dust-canvas"></canvas>

    <!-- 导航 -->
    <nav class="site-nav">
      <a href="/" class="font-shufa" style="font-size:1.1rem">末法残土图书馆</a>
      <span class="tagline hidden sm:inline">骨币会贬，记载不朽</span>
    </nav>

    <!-- 纸面 -->
    <main class="page page-reveal">
      <!-- 烛光层 -->
      <div class="page-glow" id="page-glow"></div>
      <slot />
    </main>

    <!-- 页脚 -->
    <footer class="site-footer font-kai">
      凡可立卷者，皆应先入馆藏，再论买卖与实现。
    </footer>

    <script is:inline>
      function initPage() {
        // 纸面烛光
        var page = document.querySelector(".page");
        var glow = document.getElementById("page-glow");
        if (page && glow) {
          page.addEventListener("mousemove", function(e) {
            var rect = page.getBoundingClientRect();
            glow.style.setProperty("--px", (e.clientX - rect.left) + "px");
            glow.style.setProperty("--py", (e.clientY - rect.top) + "px");
          });
        }

        // 墨迹显现
        var revealObs = new IntersectionObserver(
          function(es) { es.forEach(function(e) { if (e.isIntersecting) e.target.classList.add("visible"); }); },
          { threshold: 0, rootMargin: "0px 0px -20px 0px" }
        );
        document.querySelectorAll(".ink-reveal").forEach(function(el) { revealObs.observe(el); });

        // 详情页段落逐段浮现
        var content = document.querySelector(".book-content");
        if (content) {
          content.classList.add("animated");
          var contentObs = new IntersectionObserver(
            function(es) { es.forEach(function(e) {
              if (e.isIntersecting) { e.target.classList.add("shown"); contentObs.unobserve(e.target); }
            }); },
            { threshold: 0.1, rootMargin: "0px 0px -30px 0px" }
          );
          Array.from(content.children).forEach(function(el) { contentObs.observe(el); });
        }

        // 分馆折叠
        document.querySelectorAll(".hall-toggle").forEach(function(btn) {
          // 避免重复绑定
          if (btn.dataset.bound) return;
          btn.dataset.bound = "1";
          btn.addEventListener("click", function() {
            var hall = btn.dataset.hall;
            var body = document.querySelector('[data-hall-body="' + hall + '"]');
            if (!body) return;
            var expanded = btn.getAttribute("aria-expanded") === "true";
            btn.setAttribute("aria-expanded", String(!expanded));
            body.classList.toggle("open", !expanded);
          });
        });
      }

      // 微光跟随
      if (!window.__mouseInit) {
        window.__mouseInit = true;
        document.addEventListener("mousemove", function(e) {
          document.body.style.setProperty("--mx", e.clientX + "px");
          document.body.style.setProperty("--my", e.clientY + "px");
        });
      }

      // 浮尘
      if (!window.__dustInit) {
        window.__dustInit = true;
        var c = document.getElementById("dust-canvas");
        if (c) {
          var ctx = c.getContext("2d");
          var w = c.width = innerWidth;
          var h = c.height = innerHeight;
          addEventListener("resize", function() { w = c.width = innerWidth; h = c.height = innerHeight; });
          var ps = [];
          function mk() {
            return { x:Math.random()*w, y:Math.random()*h, vx:(Math.random()-0.5)*0.2, vy:-Math.random()*0.15-0.03, s:Math.random()*1.2+0.3, a:0, l:0, ml:Math.random()*500+250 };
          }
          for (var i=0;i<30;i++) { var p=mk(); p.l=Math.random()*p.ml; ps.push(p); }
          (function loop() {
            ctx.clearRect(0,0,w,h);
            for (var i=0;i<ps.length;i++) {
              var p=ps[i]; p.l++; p.x+=p.vx; p.y+=p.vy;
              var r=p.l/p.ml;
              p.a = r<0.2 ? r/0.2 : r>0.8 ? (1-r)/0.2 : 1;
              p.a *= 0.4;
              if (p.l>=p.ml||p.y<-10||p.x<-10||p.x>w+10) { ps[i]=mk(); continue; }
              ctx.beginPath(); ctx.arc(p.x,p.y,p.s,0,Math.PI*2);
              ctx.fillStyle = "rgba(180,165,130," + p.a + ")";
              ctx.fill();
            }
            requestAnimationFrame(loop);
          })();
        }
      }

      // 首次 + View Transitions
      initPage();
      document.addEventListener("astro:page-load", initPage);
    </script>
  </body>
</html>
