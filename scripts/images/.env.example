# Bong 图像生成环境变量。拷贝到同目录 .env（.gitignore 已屏蔽）后填值。
# 两个 backend 可共存；--backend auto（默认）会优先 cliproxy，失败 fallback openai。

# ---- CLIProxyAPI (default backend) ----
# 不填也能跑 —— 用代码里内置默认 key/base/model。
CLIPROXY_API_KEY=kiz
CLIPROXY_BASE_URL=https://cliproxy.kizunadesu.cc
CLIPROXY_MODEL=gpt-image-1536x1024

# ---- OpenAI direct (fallback) ----
# 必填才能走 --backend openai 或 auto 的 fallback。
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
# 可选（多组织 / 多项目场景）
# OPENAI_ORG_ID=org-xxx
# OPENAI_PROJECT_ID=proj-xxx
